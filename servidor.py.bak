@app.route("/api/barbearia")
def api_barbearia():
    db = get_db()
    row = db.execute("SELECT * FROM barbearia LIMIT 1").fetchone()
    if row is None:
        return jsonify({}), 404
    return jsonify(dict(row))


@app.route("/api/servicos")
def api_servicos():
    db = get_db()
    busca = request.args.get("busca", "").strip().lower()
    if busca:
        rows = db.execute("SELECT * FROM servicos WHERE ativo = 1 AND LOWER(nome) LIKE ? ORDER BY ordem, id", (f"%{busca}%",)).fetchall()
    else:
        rows = db.execute("SELECT * FROM servicos WHERE ativo = 1 ORDER BY ordem, id").fetchall()
    return jsonify([dict(row) for row in rows])


